@model EcommerceApp.ViewModels.StoreIndexViewModel
@{
    ViewData["Title"] = "Cửa hàng";
    var currentUrl = $"{Context.Request.Path}{Context.Request.QueryString}";
}

<div class="w-full space-y-6">
    @if (TempData["Message"] is string message)
    {
        <div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@message</div>
    }

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[260px_1fr]">
        <aside class="h-fit rounded-2xl border border-slate-200 bg-white p-5">
            <h2 class="text-xl font-bold text-slate-900">Bộ lọc</h2>

            <form method="get" class="mt-4 space-y-5">
                <div>
                    <label class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-500">Tìm kiếm</label>
                    <input name="searchTerm" value="@Model.SearchTerm" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="Tên hoặc mô tả..." />
                </div>

                <div>
                    <label class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-500">Danh mục</label>
                    <select name="categoryId" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                        <option value="">Tất cả danh mục</option>
                        @foreach (var category in Model.Categories)
                        {
                            if (Model.CategoryId == category.Id)
                            {
                                <option value="@category.Id" selected>@category.Name</option>
                            }
                            else
                            {
                                <option value="@category.Id">@category.Name</option>
                            }
                        }
                    </select>
                </div>

                <div>
                    <label class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-500">Khoảng giá</label>
                    <div class="grid grid-cols-2 gap-2">
                        <input type="number" step="0.01" min="0" name="minPrice" value="@Model.MinPrice" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="Từ" />
                        <input type="number" step="0.01" min="0" name="maxPrice" value="@Model.MaxPrice" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="Đến" />
                    </div>
                </div>

                <div class="flex items-center gap-2">
                    <input id="inStockOnly" type="checkbox" name="inStockOnly" value="true" checked="@(Model.InStockOnly ? "checked" : null)" class="h-4 w-4 rounded border-slate-300 text-orange-600" />
                    <label for="inStockOnly" class="text-sm text-slate-700">Chỉ hiển thị còn hàng</label>
                </div>

                <div>
                    <label class="mb-2 block text-xs font-semibold uppercase tracking-wide text-slate-500">Sắp xếp</label>
                    <select name="sortBy" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                        @if (Model.SortBy == "newest")
                        {
                            <option value="newest" selected>Mới nhất</option>
                        }
                        else
                        {
                            <option value="newest">Mới nhất</option>
                        }
                        @if (Model.SortBy == "price_asc")
                        {
                            <option value="price_asc" selected>Giá tăng dần</option>
                        }
                        else
                        {
                            <option value="price_asc">Giá tăng dần</option>
                        }
                        @if (Model.SortBy == "price_desc")
                        {
                            <option value="price_desc" selected>Giá giảm dần</option>
                        }
                        else
                        {
                            <option value="price_desc">Giá giảm dần</option>
                        }
                        @if (Model.SortBy == "name_asc")
                        {
                            <option value="name_asc" selected>Tên A-Z</option>
                        }
                        else
                        {
                            <option value="name_asc">Tên A-Z</option>
                        }
                        @if (Model.SortBy == "name_desc")
                        {
                            <option value="name_desc" selected>Tên Z-A</option>
                        }
                        else
                        {
                            <option value="name_desc">Tên Z-A</option>
                        }
                        @if (Model.SortBy == "stock_desc")
                        {
                            <option value="stock_desc" selected>Tồn kho cao</option>
                        }
                        else
                        {
                            <option value="stock_desc">Tồn kho cao</option>
                        }
                    </select>
                </div>

                <button type="submit" class="w-full rounded-lg bg-orange-500 px-4 py-2 text-sm font-semibold text-white">Áp dụng</button>
                <a asp-action="Index" class="block w-full rounded-lg border border-slate-300 px-4 py-2 text-center text-sm font-semibold text-slate-700">Đặt lại</a>
            </form>
        </aside>

        <section id="product-grid" class="space-y-5 scroll-mt-24" tabindex="-1">
            <div class="flex items-center justify-between">
                <div>
                    <h1 class="text-4xl font-bold text-slate-900">Laptop hiệu năng cao</h1>
                    <p class="mt-1 text-sm text-slate-500">Khám phá sức mạnh tối thượng cho công việc và giải trí.</p>
                </div>
                <a asp-controller="Cart" asp-action="Index" class="rounded-full bg-slate-900 px-4 py-2 text-sm font-semibold text-white">Giỏ hàng</a>
            </div>

            @if (Model.Products.Count == 0)
            {
                <div class="rounded-xl border border-slate-200 bg-white px-4 py-10 text-center text-slate-500">Không tìm thấy sản phẩm phù hợp.</div>
            }
            else
            {
                <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
                    @foreach (var product in Model.Products)
                    {
                        <div class="group relative rounded-2xl border border-slate-100 bg-white p-4 shadow-sm transition duration-300 hover:-translate-y-1 hover:shadow-lg">
                            <a asp-action="Details" asp-route-id="@product.Id" class="absolute inset-0 z-10 rounded-2xl" aria-label="Chi tiết sản phẩm @product.Name">
                                <span class="pointer-events-none absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 rounded-xl bg-black/65 px-4 py-2 text-sm font-semibold text-white opacity-0 transition-opacity duration-300 group-hover:opacity-100">
                                    Chi tiết sản phẩm
                                </span>
                            </a>

                            <div class="overflow-hidden rounded-xl">
                                <img src="@product.ImageUrl" alt="@product.Name" class="mb-4 h-44 w-full object-cover transition duration-300 group-hover:scale-110" />
                            </div>
                            <div class="mb-2 text-[11px] font-semibold uppercase tracking-[0.2em] text-orange-500">@product.Category?.Name</div>
                            <h2 class="text-xl font-bold text-slate-900">@product.Name</h2>
                            <p class="mt-1 line-clamp-2 text-sm text-slate-500">@product.Description</p>
                            <div class="mt-3 text-sm font-medium text-slate-500">Tồn kho: @product.StockQuantity</div>
                            <div class="relative z-20 mt-4 flex flex-wrap items-end justify-between gap-3">
                                <div class="text-3xl font-bold text-slate-900">@product.Price.ToString("C")</div>
                                <div class="flex flex-wrap gap-2">
                                    <form asp-controller="Wishlist" asp-action="Add" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                                        <button type="submit" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Yêu thích</button>
                                    </form>
                                    <form asp-action="AddToCart" asp-route-id="@product.Id" method="post">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="returnUrl" value="@currentUrl" />
                                        <button type="submit" class="rounded-xl bg-orange-500 px-4 py-2 text-sm font-semibold text-white">Thêm vào giỏ</button>
                                    </form>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            }

            @if (Model.TotalPages > 1)
            {
                <div class="flex items-center justify-center gap-2">
                    @if (Model.CurrentPage > 1)
                    {
                        <a asp-action="Index"
                           asp-route-page="@(Model.CurrentPage - 1)"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-minPrice="@Model.MinPrice"
                           asp-route-maxPrice="@Model.MaxPrice"
                           asp-route-inStockOnly="@Model.InStockOnly"
                           asp-route-sortBy="@Model.SortBy"
                           asp-fragment="product-grid"
                           class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700">
                            ←
                        </a>
                    }
                    @for (var i = 1; i <= Model.TotalPages; i++)
                    {
                        <a asp-action="Index"
                           asp-route-page="@i"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-minPrice="@Model.MinPrice"
                           asp-route-maxPrice="@Model.MaxPrice"
                           asp-route-inStockOnly="@Model.InStockOnly"
                           asp-route-sortBy="@Model.SortBy"
                           asp-fragment="product-grid"
                           class="@(i == Model.CurrentPage ? "rounded-lg bg-orange-500 px-3 py-2 text-sm font-semibold text-white" : "rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700")">
                            @i
                        </a>
                    }
                    @if (Model.CurrentPage < Model.TotalPages)
                    {
                        <a asp-action="Index"
                           asp-route-page="@(Model.CurrentPage + 1)"
                           asp-route-searchTerm="@Model.SearchTerm"
                           asp-route-categoryId="@Model.CategoryId"
                           asp-route-minPrice="@Model.MinPrice"
                           asp-route-maxPrice="@Model.MaxPrice"
                           asp-route-inStockOnly="@Model.InStockOnly"
                           asp-route-sortBy="@Model.SortBy"
                           asp-fragment="product-grid"
                           class="rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-semibold text-slate-700">
                            →
                        </a>
                    }
                </div>
            }
        </section>
    </div>
</div>

@section Scripts {
    <script>
        if (window.location.hash === '#product-grid') {
            document.getElementById('product-grid')?.focus();
        }
    </script>
}
