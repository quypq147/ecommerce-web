@model EcommerceApp.Models.Product

@{
    ViewData["Title"] = Model.Name + " - Đánh giá";
}

<section class="w-full">
    <div class="mx-auto max-w-5xl space-y-6">
        <a href="@Url.Action("Details", "Store", new { id = Model.Id })"
           class="inline-flex items-center gap-1 text-sm font-semibold text-primary hover:underline">
            <span class="material-symbols-outlined text-base">arrow_back</span>
            <span>Quay lại sản phẩm</span>
        </a>

        @if (TempData["ReviewMessage"] is string reviewMessage)
        {
            <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                @reviewMessage
            </div>
        }

        <div class="rounded-2xl border border-outline-variant/30 bg-white p-6 shadow-sm">
            <div class="flex flex-col gap-3 md:flex-row md:items-center md:justify-between">
                <div>
                    <h1 class="text-2xl font-black text-on-surface">@Model.Name</h1>
                    <p class="mt-1 text-sm text-secondary">Để lại đánh giá và xếp hạng cho sản phẩm này</p>
                </div>
                <div class="rounded-xl bg-surface-container-low px-4 py-3 text-sm">
                    <p class="font-semibold text-on-surface">Điểm trung bình: @Model.AverageRating.ToString("0.0")/5</p>
                    <p class="text-secondary">@Model.ReviewCount đánh giá</p>
                </div>
            </div>
        </div>

        <div class="rounded-2xl border border-outline-variant/30 bg-white p-6 shadow-sm">
            <h2 class="mb-4 text-xl font-black text-on-surface">Thêm đánh giá của bạn</h2>

            @if (User.Identity?.IsAuthenticated == true)
            {
                <form method="post" action="@Url.Action("Create", "Review")" class="space-y-4">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="productId" value="@Model.Id" />

                    <div>
                        <label for="reviewerName" class="mb-2 block text-sm font-semibold text-on-surface">Tên của bạn</label>
                        <input type="text"
                               class="w-full rounded-xl border border-outline-variant/50 bg-white px-4 py-2.5 text-sm focus:border-primary-container focus:outline-none focus:ring-2 focus:ring-primary-fixed"
                               id="reviewerName"
                               name="reviewerName"
                               placeholder="Ví dụ: Nguyễn Văn A"
                               required />
                    </div>

                    <div>
                        <label for="rating" class="mb-2 block text-sm font-semibold text-on-surface">Đánh giá</label>
                        <select class="w-full rounded-xl border border-outline-variant/50 bg-white px-4 py-2.5 text-sm focus:border-primary-container focus:outline-none focus:ring-2 focus:ring-primary-fixed"
                                id="rating"
                                name="rating"
                                required>
                            <option value="">Chọn số sao</option>
                            <option value="5">⭐⭐⭐⭐⭐ 5 Sao - Xuất sắc</option>
                            <option value="4">⭐⭐⭐⭐ 4 Sao - Rất tốt</option>
                            <option value="3">⭐⭐⭐ 3 Sao - Tốt</option>
                            <option value="2">⭐⭐ 2 Sao - Tạm</option>
                            <option value="1">⭐ 1 Sao - Kém</option>
                        </select>
                    </div>

                    <div>
                        <label for="comment" class="mb-2 block text-sm font-semibold text-on-surface">Nhận xét của bạn</label>
                        <textarea class="w-full rounded-xl border border-outline-variant/50 bg-white px-4 py-3 text-sm focus:border-primary-container focus:outline-none focus:ring-2 focus:ring-primary-fixed"
                                  id="comment"
                                  name="comment"
                                  rows="5"
                                  maxlength="500"
                                  placeholder="Chia sẻ cảm nhận của bạn về chất lượng, hiệu năng, đóng gói, thời gian giao hàng..."
                                  required></textarea>
                        <p class="mt-1 text-xs text-secondary">Tối đa 500 ký tự.</p>
                    </div>

                    <div class="flex items-center gap-2 pt-2">
                        <button type="submit"
                                class="inline-flex items-center gap-1 rounded-xl bg-primary-container px-4 py-2 text-sm font-bold text-on-primary shadow-sm hover:opacity-95">
                            <span class="material-symbols-outlined text-base">send</span>
                            <span>Gửi đánh giá</span>
                        </button>
                        <a href="@Url.Action("Details", "Store", new { id = Model.Id })"
                           class="rounded-xl border border-outline-variant/50 bg-white px-4 py-2 text-sm font-semibold text-secondary hover:bg-surface-container-low">
                            Hủy
                        </a>
                    </div>
                </form>
            }
            else
            {
                <div class="rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
                    Bạn cần đăng nhập và có đơn hàng đã giao để đánh giá sản phẩm.
                    <a asp-controller="Account" asp-action="Login" class="ml-1 font-semibold text-primary hover:underline">Đăng nhập ngay</a>
                </div>
            }
        </div>

        <div class="rounded-2xl border border-outline-variant/30 bg-white p-6 shadow-sm">
            <h2 class="mb-3 text-xl font-black text-on-surface">Đánh giá khách hàng</h2>
            <div class="rounded-xl bg-surface-container-low px-4 py-8 text-center text-sm text-secondary">
                Chưa có đánh giá nào. Hãy là người đầu tiên đánh giá sản phẩm này!
            </div>
        </div>
    </div>
</section>
