<!DOCTYPE html>

<html lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            "colors": {
                "on-primary-container": "#623200",
                "on-error": "#ffffff",
                "on-tertiary-container": "#004360",
                "tertiary-fixed": "#c7e7ff",
                "inverse-on-surface": "#eff1f3",
                "surface-variant": "#e0e3e5",
                "on-secondary-container": "#5c647a",
                "surface-container-lowest": "#ffffff",
                "on-primary-fixed": "#2f1500",
                "secondary-container": "#dae2fd",
                "on-secondary-fixed": "#131b2e",
                "secondary-fixed-dim": "#bec6e0",
                "primary-container": "#ff8c00",
                "on-error-container": "#93000a",
                "surface": "#f7f9fb",
                "tertiary-container": "#00b5fc",
                "on-background": "#191c1e",
                "outline-variant": "#ddc1ae",
                "on-tertiary": "#ffffff",
                "on-surface": "#191c1e",
                "on-secondary": "#ffffff",
                "surface-container-high": "#e6e8ea",
                "surface-container-highest": "#e0e3e5",
                "primary-fixed-dim": "#ffb77d",
                "background": "#f7f9fb",
                "error": "#ba1a1a",
                "primary": "#904d00",
                "tertiary": "#00658f",
                "outline": "#897362",
                "surface-dim": "#d8dadc",
                "inverse-primary": "#ffb77d",
                "primary-fixed": "#ffdcc3",
                "on-primary-fixed-variant": "#6e3900",
                "secondary": "#565e74",
                "error-container": "#ffdad6",
                "surface-container": "#eceef0",
                "on-surface-variant": "#564334",
                "inverse-surface": "#2d3133",
                "tertiary-fixed-dim": "#85cfff",
                "on-tertiary-fixed-variant": "#004c6c",
                "surface-bright": "#f7f9fb",
                "secondary-fixed": "#dae2fd",
                "surface-container-low": "#f2f4f6",
                "on-secondary-fixed-variant": "#3f465c",
                "on-primary": "#ffffff",
                "on-tertiary-fixed": "#001e2e",
                "surface-tint": "#904d00"
            },
            "borderRadius": {
                "DEFAULT": "0.25rem",
                "lg": "0.5rem",
                "xl": "0.75rem",
                "full": "9999px"
            },
            "fontFamily": {
                "headline": ["Plus Jakarta Sans"],
                "body": ["Inter"],
                "label": ["Inter"]
            }
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .editorial-grid {
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: 2rem;
        }
    </style>
</head>
<body class="bg-surface text-on-surface font-body selection:bg-primary-container selection:text-on-primary-container overflow-x-hidden">
<main class="h-screen p-4 md:p-6">
<section class="max-w-screen-2xl mx-auto px-4 md:px-8">
<div class="relative overflow-hidden rounded-[2.5rem] bg-slate-900 h-[calc(100vh-2rem)] md:h-[calc(100vh-3rem)] flex items-center">
    <div class="absolute inset-0 z-0">
        <img alt="High-performance minimalist workstation" class="w-full h-full object-cover opacity-55" data-alt="Modern minimalist aesthetic workstation with sleek monitors, mechanical keyboard, and premium PC case on a dark desk with soft ambient lighting" src="https://lh3.googleusercontent.com/aida-public/AB6AXuC2ZYX3QB0MaMnFlr8mhdI4_ieXRzzqmGOeTToxiGF3Eo1IC5YpaACQyQ19pfd-LhS_flEzPVZTkxUxWmp1-EGD40lmKC_5jQCjUTc6nzPZJtkivnlRpcbdunbG8nFbgOWopa4dk9e2l6Au_RcFeRsJXauBH24aUhFGvQpwktClMSP94qlSqTqT2pNYbUFZdKrv1JR_71kVKq5a1ddY-VeK9SbCZUjDv5XCkax2ugdxZDu7tmpsMNr0RSelIggY3m0BuQHwkHt1Lw"/>
        <div class="absolute inset-0 bg-gradient-to-r from-black/85 via-black/55 to-black/20"></div>
    </div>

    <div class="relative z-10 w-full px-8 md:px-16 py-16">
        <div class="max-w-4xl">
            <span class="inline-flex items-center gap-2 px-4 py-1 rounded-full bg-primary-container text-on-primary-container text-xs font-bold tracking-widest uppercase mb-6">TechCurator</span>

            <h1 class="text-4xl md:text-6xl lg:text-7xl font-headline font-extrabold text-white leading-[0.95] tracking-tighter mb-6">
                Nâng tầm góc máy của bạn<br />
                với hiệu năng <span class="text-primary-container">đỉnh cao</span>
            </h1>

            <p class="text-lg md:text-xl text-slate-200 font-body max-w-2xl mb-10 leading-relaxed">
                TechCurator tuyển chọn laptop, workstation và linh kiện cao cấp cho nhà sáng tạo, kỹ sư và game thủ chuyên nghiệp.
            </p>

            <div class="flex flex-wrap gap-4">
                <a asp-controller="Store" asp-action="Index" class="bg-gradient-to-r from-primary to-primary-container text-white px-8 py-4 rounded-xl font-bold text-base md:text-lg hover:shadow-[0_0_30px_rgba(255,140,0,0.35)] transition-all flex items-center gap-2">
                    Khám phá ngay <span class="material-symbols-outlined">arrow_forward</span>
                </a>
            </div>
        </div>
    </div>
</div>
</section>
</main>
</body></html>