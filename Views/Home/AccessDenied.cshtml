@{
    Layout = null;
}

<!DOCTYPE html>
<html class="light" lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Access Denied | TechCurator</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#904d00",
                        "primary-container": "#ff8c00",
                        surface: "#f7f9fb",
                        "on-surface": "#191c1e",
                        "surface-container-low": "#f2f4f6",
                        "surface-container-high": "#e6e8ea",
                        error: "#ba1a1a",
                        secondary: "#565e74"
                    }
                }
            }
        }
    </script>
    <style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
    </style>
</head>
<body class="min-h-screen bg-surface text-on-surface font-['Inter'] antialiased">
    <main class="min-h-screen flex items-center justify-center p-6 sm:p-12">
        <div class="max-w-3xl w-full grid grid-cols-1 lg:grid-cols-2 gap-10 items-center">
            <div class="relative">
                <div class="rounded-[2.5rem] bg-white p-12 shadow-2xl shadow-slate-200/50 border border-white/40 flex flex-col items-center justify-center aspect-square">
                    <div class="relative mb-8">
                        <div class="w-32 h-32 bg-surface-container-high rounded-full flex items-center justify-center">
                            <span class="material-symbols-outlined text-6xl text-primary" style="font-variation-settings: 'FILL' 1;">lock</span>
                        </div>
                        <div class="absolute -bottom-2 -right-2 w-12 h-12 bg-error rounded-full flex items-center justify-center text-white border-4 border-white">
                            <span class="material-symbols-outlined text-xl">block</span>
                        </div>
                    </div>
                    <span class="text-primary font-black text-7xl tracking-tighter opacity-10">403</span>
                </div>
            </div>

            <div class="space-y-6">
                <div>
                    <h3 class="text-slate-400 font-bold uppercase tracking-[0.2em] text-xs mb-3">Security Protocol</h3>
                    <h1 class="text-slate-900 font-black text-5xl tracking-tight leading-[1.1]">
                        Access <span class="text-primary italic">Denied.</span>
                    </h1>
                </div>

                <p class="text-slate-600 text-lg leading-relaxed">
                    You cannot access this page because you are not signed in or your account does not have <strong>admin</strong> permission.
                </p>

                <p class="text-slate-500 text-sm leading-relaxed border-l-2 border-slate-200 pl-4 py-1">
                    Please sign in with an admin account or contact support to request permission.
                </p>

                <div class="flex flex-col sm:flex-row items-center gap-4 pt-2">
                    <a class="w-full sm:w-auto px-8 py-4 bg-gradient-to-br from-primary to-primary-container text-white font-bold rounded-xl shadow-lg shadow-primary/20 hover:shadow-primary/40 transition-all text-center"
                       href="/Store">
                        Go to Store
                    </a>
                    <a class="w-full sm:w-auto px-8 py-4 bg-surface-container-high text-on-surface font-semibold rounded-xl hover:bg-slate-200 transition-colors text-center"
                       href="/Account/Login">
                        Sign In
                    </a>
                </div>
            </div>
        </div>
    </main>
</body>
</html>
