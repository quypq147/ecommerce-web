                <div class="step">
                    <div class="step-number">1</div>
                    <div class="step-text">Bạn sẽ sớm nhận được email xác nhận đơn hàng</div>
                </div>
                <div class="step">
                    <div class="step-number">2</div>
                    <div class="step-text">Đơn hàng sẽ được xử lý và chuẩn bị giao</div>
                </div>
                <div class="step">
