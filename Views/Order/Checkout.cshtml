@model CartViewModel

@{
    ViewData["Title"] = "Thanh toán";
}

<style>
    .checkout-container {
        background: #f8f9fa;
        min-height: 100vh;
        padding: 40px 0;
    }
    
    .order-summary-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        padding: 30px;
        margin-bottom: 30px;
    }
    
    .shipping-card {
        background: white;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
        padding: 30px;
    }
    
    .order-summary-table {
        border: none;
    }
    
    .order-summary-table thead {
        background-color: #f8f9fa;
        border-bottom: 2px solid #dee2e6;
    }
    
    .order-summary-table tbody tr {
        border-bottom: 1px solid #dee2e6;
    }
    
    .order-summary-table tbody tr td {
        padding: 15px;
        vertical-align: middle;
    }
    
    .order-summary-table tfoot tr {
        background-color: #f8f9fa;
        font-weight: 600;
    }
    
    .order-summary-table tfoot tr td,
    .order-summary-table tfoot tr th {
        padding: 15px;
        border: none;
        color: #333;
    }
    
    .section-title {
        font-size: 20px;
        font-weight: 600;
        color: #333;
        margin-bottom: 25px;
        padding-bottom: 15px;
        border-bottom: 2px solid #e9ecef;
    }
    
    .form-label {
        font-weight: 600;
        color: #333;
        margin-bottom: 8px;
    }
    
    .form-control {
        border: 1px solid #ddd;
        border-radius: 8px;
        padding: 12px 15px;
        font-size: 14px;
        transition: all 0.3s ease;
    }
    
    .form-control:focus {
        border-color: #999;
        box-shadow: 0 0 0 3px rgba(0, 0, 0, 0.05);
    }
    
    .btn-place-order {
        background: #2c2c2c;
        border: none;
        border-radius: 8px;
        padding: 12px 30px;
        font-weight: 600;
        color: white;
        transition: all 0.2s ease;
    }
    
    .btn-place-order:hover {
        background: #444;
        color: white;
        text-decoration: none;
    }
    
    .btn-back {
        background-color: #e9ecef;
        border: none;
        border-radius: 8px;
        padding: 12px 30px;
        font-weight: 600;
        color: #333;
        transition: all 0.3s ease;
    }
    
    .btn-back:hover {
        background-color: #dee2e6;
        color: #333;
        text-decoration: none;
    }
    
    .form-row {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    
    .form-row .mb-3 {
        margin-bottom: 0;
    }
    
    .full-width-field {
        grid-column: 1 / -1;
    }

    .badge {
        background-color: #e9ecef;
        color: #333;
        font-weight: 600;
    }
    
    .order-detail-header {
        color: #333;
        font-weight: 700;
        margin-bottom: 20px;
    }
    
    .detail-row {
        display: flex;
        justify-content: space-between;
        padding: 10px 0;
        border-bottom: 1px solid #eee;
        color: #666;
    }
    
    .detail-row strong {
        color: #333;
    }
    
    .trust-badge {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 15px;
        margin-top: 20px;
    }
    
    .trust-badge p {
        font-size: 12px;
        color: #666;
        margin: 0;
        line-height: 1.6;
    }
    
    .order-total {
        font-size: 18px;
        font-weight: 700;
        color: #333;
    }
    
    .checkout-header {
        color: #333;
        margin-bottom: 30px;
    }
    
    .checkout-header h1 {
        font-size: 32px;
        font-weight: 700;
        margin-bottom: 10px;
    }
    
    .checkout-header p {
        font-size: 16px;
        color: #666;
    }
</style>

<div class="checkout-container">
    <div class="container">
        <div class="checkout-header">
            <h1>Thanh toán an toàn</h1>
            <p>Hoàn tất đơn hàng chỉ với vài bước</p>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <div class="order-summary-card">
                    <h3 class="section-title">📦 Tóm tắt đơn hàng</h3>
                    <table class="table order-summary-table">
                        <thead>
                            <tr>
                                <th>Sản phẩm</th>
                                <th>Giá</th>
                                <th>Số lượng</th>
                                <th>Tổng</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Items)
                            {
                                <tr>
                                    <td>
                                        <strong>@item.Product.Name</strong>
                                    </td>
                                    <td>$@item.Product.Price.ToString("F2")</td>
                                    <td>
                                        <span class="badge bg-info">@item.Quantity</span>
                                    </td>
                                    <td>
                                        <strong class="order-total">$@item.LineTotal.ToString("F2")</strong>
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot>
                            <tr>
                                <td colspan="3" style="text-align: right;">Tổng cộng:</td>
                                <td style="font-size: 20px;">$@Model.Total.ToString("F2")</td>
                            </tr>
                        </tfoot>
                    </table>
                </div>

                <div class="shipping-card">
                    <h3 class="section-title">🚚 Thông tin giao hàng</h3>
                    <form method="post" action="@Url.Action("PlaceOrder", "Order")">
                        @Html.AntiForgeryToken()
                        
                        <div class="form-row">
                            <div class="mb-3">
                                <label for="customerName" class="form-label">Họ và tên</label>
                                <input type="text" class="form-control" id="customerName" name="customerName" placeholder="Nguyễn Văn A" required>
                            </div>

                            <div class="mb-3">
                                <label for="customerEmail" class="form-label">Địa chỉ email</label>
                                <input type="email" class="form-control" id="customerEmail" name="customerEmail" placeholder="email@example.com" required>
                            </div>
                        </div>

                        <div class="mb-3 full-width-field">
                            <label for="shippingAddress" class="form-label">Địa chỉ giao hàng</label>
                            <textarea class="form-control" id="shippingAddress" name="shippingAddress" rows="3" placeholder="Nhập đầy đủ địa chỉ giao hàng..." required></textarea>
                        </div>

                        <div class="mb-4 full-width-field">
                            <label for="phoneNumber" class="form-label">Số điện thoại</label>
                            <input type="tel" class="form-control" id="phoneNumber" name="phoneNumber" placeholder="09xxxxxxxx" required>
                        </div>

                        <div class="d-flex gap-3">
                            <a href="@Url.Action("Index", "Cart")" class="btn btn-back">← Quay lại giỏ hàng</a>
                            <button type="submit" class="btn btn-place-order">Hoàn tất đơn hàng →</button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="order-summary-card" style="position: sticky; top: 20px; margin-top: 30px;">
                    <h5 class="order-detail-header">Chi tiết đơn hàng</h5>
                    
                    <div class="detail-row">
                        <span>Tạm tính:</span>
                        <strong>$@Model.Total.ToString("F2")</strong>
                    </div>
                    
                    <div class="detail-row">
                        <span>Vận chuyển:</span>
                        <strong style="color: #27ae60;">MIỄN PHÍ</strong>
                    </div>
                    
                    <div class="detail-row">
                        <span>Thuế:</span>
                        <strong>$0.00</strong>
                    </div>
                    
                    <div style="padding-top: 15px; padding-bottom: 0; border-top: 2px solid #e9ecef; margin-top: 15px;">
                        <div class="detail-row" style="border-bottom: none; font-size: 16px;">
                            <span><strong>Tổng:</strong></span>
                            <strong style="font-size: 18px; color: #2c2c2c;">$@Model.Total.ToString("F2")</strong>
                        </div>
                    </div>

                    <div class="trust-badge">
                        <p>
                            ✓ Xử lý thanh toán an toàn<br>
                            ✓ Miễn phí vận chuyển toàn quốc<br>
                            ✓ Hoàn tiền trong 30 ngày
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
