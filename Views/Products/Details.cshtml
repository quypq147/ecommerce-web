@model EcommerceApp.Models.Product
@{
    ViewData["Title"] = "Chi tiết sản phẩm";
}

<div class="mx-auto max-w-3xl space-y-6">
    <h1 class="text-3xl font-bold text-slate-900">Chi tiết sản phẩm</h1>

    <div class="space-y-3 rounded-2xl bg-white p-6 shadow-sm">
        <div><span class="font-semibold text-slate-700">Tên:</span> @Model.Name</div>
        <div><span class="font-semibold text-slate-700">Mô tả:</span> @Model.Description</div>
        <div><span class="font-semibold text-slate-700">Danh mục:</span> @Model.Category?.Name</div>
        <div><span class="font-semibold text-slate-700">Giá:</span> @Model.Price.ToString("C")</div>
        <div><span class="font-semibold text-slate-700">Tồn kho:</span> @Model.StockQuantity</div>
        <div><span class="font-semibold text-slate-700">URL hình ảnh:</span> @Model.ImageUrl</div>
    </div>

    <div class="flex gap-3">
        <a asp-action="Edit" asp-route-id="@Model.Id" class="rounded-lg bg-orange-600 px-4 py-2 font-semibold text-white">Sửa</a>
        <a asp-action="Index" class="rounded-lg border border-slate-300 px-4 py-2 font-semibold text-slate-700">Quay lại</a>
    </div>
</div>
