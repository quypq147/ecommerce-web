@model IEnumerable<EcommerceApp.Models.Product>
@{
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="w-full space-y-6">
    <div class="flex items-center justify-between">
        <h1 class="text-3xl font-bold text-slate-900">Quản lý sản phẩm</h1>
        <a asp-action="Create" class="rounded-full bg-orange-600 px-4 py-2 text-sm font-semibold text-white">Tạo mới</a>
    </div>

    <form method="get" class="grid gap-4 rounded-xl border border-slate-200 bg-white p-4 md:grid-cols-3">
        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Tìm kiếm</label>
            <input name="searchString" value="@ViewData["SearchString"]" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" placeholder="Tên sản phẩm" />
        </div>
        <div>
            <label class="mb-1 block text-sm font-medium text-slate-700">Danh mục</label>
            <select name="categoryId" asp-items="ViewBag.CategoryId" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm">
                <option value="">Tất cả danh mục</option>
            </select>
        </div>
        <div class="flex items-end gap-2">
            <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white">Lọc</button>
            <a asp-action="Index" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Đặt lại</a>
        </div>
    </form>

    <div class="overflow-hidden rounded-2xl bg-white shadow-sm">
        <table class="min-w-full divide-y divide-slate-200">
            <thead class="bg-slate-50">
                <tr>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">Tên</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">Danh mục</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">Giá</th>
                    <th class="px-4 py-3 text-left text-xs font-semibold uppercase text-slate-600">Tồn kho</th>
                    <th class="px-4 py-3"></th>
                </tr>
            </thead>
            <tbody class="divide-y divide-slate-100">
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="px-4 py-3 text-sm text-slate-800">@item.Name</td>
                        <td class="px-4 py-3 text-sm text-slate-600">@item.Category?.Name</td>
                        <td class="px-4 py-3 text-sm text-slate-800">@item.Price.ToString("C")</td>
                        <td class="px-4 py-3 text-sm text-slate-600">@item.StockQuantity</td>
                        <td class="px-4 py-3 text-right text-sm">
                            <a asp-action="Details" asp-route-id="@item.Id" class="mr-2 text-slate-700">Chi tiết</a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="mr-2 text-orange-600">Sửa</a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="text-red-600">Xóa</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
