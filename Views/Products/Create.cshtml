@model EcommerceApp.Models.Product
@{
    ViewData["Title"] = "Create Product";
}

<div class="mx-auto max-w-3xl space-y-6">
    <h1 class="text-3xl font-bold text-slate-900">Create Product</h1>

    <form asp-action="Create" method="post" class="space-y-4 rounded-2xl bg-white p-6 shadow-sm">
        <div asp-validation-summary="ModelOnly" class="text-sm text-red-600"></div>

        <div>
            <label asp-for="Name" class="mb-1 block text-sm font-medium text-slate-700"></label>
            <input asp-for="Name" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <span asp-validation-for="Name" class="text-sm text-red-600"></span>
        </div>

        <div>
            <label asp-for="Description" class="mb-1 block text-sm font-medium text-slate-700"></label>
            <textarea asp-for="Description" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></textarea>
            <span asp-validation-for="Description" class="text-sm text-red-600"></span>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
            <div>
                <label asp-for="Price" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="Price" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <span asp-validation-for="Price" class="text-sm text-red-600"></span>
            </div>
            <div>
                <label asp-for="StockQuantity" class="mb-1 block text-sm font-medium text-slate-700"></label>
                <input asp-for="StockQuantity" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
                <span asp-validation-for="StockQuantity" class="text-sm text-red-600"></span>
            </div>
        </div>

        <div>
            <label asp-for="ImageUrl" class="mb-1 block text-sm font-medium text-slate-700"></label>
            <input asp-for="ImageUrl" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <span asp-validation-for="ImageUrl" class="text-sm text-red-600"></span>
        </div>

        <div>
            <label asp-for="CategoryId" class="mb-1 block text-sm font-medium text-slate-700"></label>
            <select asp-for="CategoryId" asp-items="ViewBag.CategoryId" class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm"></select>
            <span asp-validation-for="CategoryId" class="text-sm text-red-600"></span>
        </div>

        <div class="flex gap-3">
            <button type="submit" class="rounded-lg bg-orange-600 px-4 py-2 font-semibold text-white">Create</button>
            <a asp-action="Index" class="rounded-lg border border-slate-300 px-4 py-2 font-semibold text-slate-700">Back</a>
        </div>
    </form>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
