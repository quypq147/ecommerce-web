@model EcommerceApp.ViewModels.Account.ForgotPasswordViewModel
@{
    ViewData["Title"] = "Quên mật khẩu";
}

<form method="post" class="space-y-6">
    @Html.AntiForgeryToken()
    <div>
        <h2 class="text-2xl font-bold tracking-tight text-on-surface mb-2">Khôi phục mật khẩu</h2>
        <p class="text-secondary text-sm">Nhập email để tiếp tục đặt lại mật khẩu.</p>
    </div>

    <div asp-validation-summary="All" class="text-sm text-red-600"></div>

    <div class="space-y-1.5">
        <label asp-for="Email" class="text-[0.75rem] font-semibold text-secondary ml-1"></label>
        <input asp-for="Email" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl" />
        <span asp-validation-for="Email" class="text-xs text-red-600"></span>
    </div>

    <button type="submit" class="w-full py-4 bg-gradient-to-r from-primary to-primary-container text-white font-bold rounded-xl">
        Tiếp tục
    </button>

    <a asp-action="Login" class="block text-center text-sm text-secondary hover:underline">Quay lại đăng nhập</a>
</form>
