@model EcommerceApp.ViewModels.Account.ChangePasswordViewModel
@{
    ViewData["Title"] = "Đổi mật khẩu";
    Layout = "_Layout";
    var displayName = User.Identity?.Name ?? "User";
}

<div class="w-full">
    <div class="flex flex-col lg:flex-row gap-8">
        <aside class="w-full lg:w-64 space-y-2">
            <div class="p-4 mb-6 rounded-xl bg-surface-container-low border-none">
                <div class="flex items-center space-x-3">
                    <div class="w-12 h-12 rounded-full overflow-hidden bg-primary-fixed ring-2 ring-primary-container flex items-center justify-center text-primary font-bold">
                        @displayName[..1].ToUpperInvariant()
                    </div>
                    <div>
                        <p class="font-headline font-bold text-slate-900 leading-tight">@displayName</p>
                        <p class="text-xs text-slate-500">TechCurator Member</p>
                    </div>
                </div>
            </div>
            <nav class="space-y-1">
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg text-slate-500 hover:bg-orange-50 transition-all group" asp-action="Profile">
                    <span class="material-symbols-outlined group-hover:text-orange-500">person</span>
                    <span class="text-sm">Hồ sơ người dùng</span>
                </a>
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg text-slate-500 hover:bg-orange-50 transition-all group" asp-action="OrderHistory">
                    <span class="material-symbols-outlined group-hover:text-orange-500">shopping_bag</span>
                    <span class="text-sm">Đơn hàng của tôi</span>
                </a>
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg bg-orange-50 text-orange-600 border-r-4 border-orange-600 font-semibold" asp-action="ChangePassword">
                    <span class="material-symbols-outlined">lock</span>
                    <span class="text-sm">Đổi mật khẩu</span>
                </a>
                <form asp-action="Logout" method="post" class="block">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-slate-500 hover:bg-orange-50 transition-all group text-left">
                        <span class="material-symbols-outlined group-hover:text-orange-500">logout</span>
                        <span class="text-sm">Đăng xuất</span>
                    </button>
                </form>
            </nav>
        </aside>

        <div class="flex-1 max-w-2xl bg-white rounded-2xl p-8 shadow-sm border border-slate-100">
            <div class="flex items-center justify-between mb-6">
                <h2 class="text-2xl font-bold">Đổi mật khẩu</h2>
                <a asp-action="Profile" class="text-sm font-semibold text-orange-600 hover:underline">Quay lại hồ sơ</a>
            </div>

            <form method="post" class="space-y-5">
                @Html.AntiForgeryToken()
                <div asp-validation-summary="All" class="text-sm text-red-600"></div>

                <div>
                    <label asp-for="CurrentPassword" class="block text-sm font-semibold mb-1"></label>
                    <input asp-for="CurrentPassword" class="w-full rounded-xl border-slate-200" />
                    <span asp-validation-for="CurrentPassword" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="NewPassword" class="block text-sm font-semibold mb-1"></label>
                    <input asp-for="NewPassword" class="w-full rounded-xl border-slate-200" />
                    <span asp-validation-for="NewPassword" class="text-xs text-red-600"></span>
                </div>

                <div>
                    <label asp-for="ConfirmPassword" class="block text-sm font-semibold mb-1"></label>
                    <input asp-for="ConfirmPassword" class="w-full rounded-xl border-slate-200" />
                    <span asp-validation-for="ConfirmPassword" class="text-xs text-red-600"></span>
                </div>

                <button type="submit" class="px-6 py-3 rounded-xl bg-orange-600 text-white font-semibold">Cập nhật mật khẩu</button>
            </form>
        </div>
    </div>
</div>
