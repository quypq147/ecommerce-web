@model EcommerceApp.ViewModels.Account.ResetPasswordViewModel
@{
    ViewData["Title"] = "Đặt lại mật khẩu";
}

<form method="post" class="space-y-6">
    @Html.AntiForgeryToken()
    <input asp-for="Email" type="hidden" />
    <input asp-for="Token" type="hidden" />

    <div>
        <h2 class="text-2xl font-bold tracking-tight text-on-surface mb-2">Đặt lại mật khẩu</h2>
        <p class="text-secondary text-sm">Tạo mật khẩu mới cho tài khoản của bạn.</p>
    </div>

    <div asp-validation-summary="All" class="text-sm text-red-600"></div>

    <div class="space-y-1.5">
        <label asp-for="Password" class="text-[0.75rem] font-semibold text-secondary ml-1"></label>
        <input asp-for="Password" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl" />
        <span asp-validation-for="Password" class="text-xs text-red-600"></span>
    </div>

    <div class="space-y-1.5">
        <label asp-for="ConfirmPassword" class="text-[0.75rem] font-semibold text-secondary ml-1"></label>
        <input asp-for="ConfirmPassword" class="w-full px-4 py-3 bg-surface-container-low border-none rounded-xl" />
        <span asp-validation-for="ConfirmPassword" class="text-xs text-red-600"></span>
    </div>

    <button type="submit" class="w-full py-4 bg-gradient-to-r from-primary to-primary-container text-white font-bold rounded-xl">
        Cập nhật mật khẩu
    </button>
</form>
