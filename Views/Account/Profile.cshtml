@model EcommerceApp.ViewModels.Account.ProfileViewModel
@{
    ViewData["Title"] = "Hồ sơ người dùng";
    Layout = "_Layout";
}

<div class="w-full">
    <div class="flex flex-col lg:flex-row gap-8">
        <aside class="w-full lg:w-64 space-y-2">
            <div class="p-4 mb-6 rounded-xl bg-surface-container-low border-none">
                <div class="flex items-center space-x-3">
                    <div class="w-12 h-12 rounded-full overflow-hidden bg-primary-fixed ring-2 ring-primary-container flex items-center justify-center text-primary font-bold">
                        @(string.IsNullOrWhiteSpace(Model.DisplayName) ? "U" : Model.DisplayName[..1].ToUpperInvariant())
                    </div>
                    <div>
                        <p class="font-headline font-bold text-slate-900 leading-tight">@Model.DisplayName</p>
                        <p class="text-xs text-slate-500">TechCurator Member</p>
                    </div>
                </div>
            </div>
            <nav class="space-y-1">
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg bg-orange-50 text-orange-600 border-r-4 border-orange-600 font-semibold" asp-action="Profile">
                    <span class="material-symbols-outlined">person</span>
                    <span class="text-sm">Hồ sơ người dùng</span>
                </a>
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg text-slate-500 hover:bg-orange-50 transition-all group" asp-action="OrderHistory">
                    <span class="material-symbols-outlined group-hover:text-orange-500">shopping_bag</span>
                    <span class="text-sm">Đơn hàng của tôi</span>
                </a>
                <a class="flex items-center space-x-3 px-4 py-3 rounded-lg text-slate-500 hover:bg-orange-50 transition-all group" asp-action="ChangePassword">
                    <span class="material-symbols-outlined group-hover:text-orange-500">lock</span>
                    <span class="text-sm">Đổi mật khẩu</span>
                </a>
                <form asp-action="Logout" method="post" class="block">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="w-full flex items-center space-x-3 px-4 py-3 rounded-lg text-slate-500 hover:bg-orange-50 transition-all group text-left">
                        <span class="material-symbols-outlined group-hover:text-orange-500">logout</span>
                        <span class="text-sm">Đăng xuất</span>
                    </button>
                </form>
            </nav>
        </aside>

        <div class="flex-1 space-y-8">
            <section class="relative overflow-hidden rounded-3xl bg-slate-900 p-8 md:p-12">
                <div class="absolute top-0 right-0 w-1/2 h-full opacity-20 pointer-events-none">
                    <div class="absolute inset-0 bg-gradient-to-l from-orange-600 to-transparent"></div>
                </div>
                <div class="relative z-10">
                    <h1 class="text-4xl md:text-5xl font-headline font-black text-white tracking-tighter mb-2">Hồ sơ người dùng</h1>
                    <p class="text-slate-300 max-w-md font-body">Quản lý thông tin cá nhân và cài đặt bảo mật để có trải nghiệm mua sắm tốt nhất tại TechCurator.</p>
                    <div class="mt-8 flex items-center gap-4 bg-white/10 backdrop-blur-md p-4 rounded-2xl w-fit border border-white/10">
                        <div class="w-16 h-16 rounded-xl overflow-hidden shadow-2xl bg-white/20 flex items-center justify-center text-white text-xl font-bold">
                            @(string.IsNullOrWhiteSpace(Model.DisplayName) ? "U" : Model.DisplayName[..1].ToUpperInvariant())
                        </div>
                        <div>
                            <h2 class="text-xl font-headline font-bold text-white">@Model.DisplayName</h2>
                            <p class="text-orange-400 text-sm font-medium">@Model.Email</p>
                        </div>
                    </div>
                </div>
            </section>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
                <section class="bg-surface-container-lowest rounded-3xl p-8 shadow-sm">
                    <div class="flex items-center gap-3 mb-8">
                        <div class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center text-orange-600">
                            <span class="material-symbols-outlined">badge</span>
                        </div>
                        <h3 class="text-xl font-headline font-extrabold text-slate-900">Thông tin cá nhân</h3>
                    </div>

                    @if (TempData["StatusMessage"] is string statusMessage)
                    {
                        <div class="mb-4 rounded-lg bg-green-50 text-green-700 px-4 py-3 text-sm">@statusMessage</div>
                    }

                    <form method="post" class="space-y-6">
                        @Html.AntiForgeryToken()
                        <div asp-validation-summary="All" class="text-sm text-red-600"></div>

                        <div class="space-y-2">
                            <label asp-for="DisplayName" class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1"></label>
                            <input asp-for="DisplayName" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-orange-500/20 text-slate-900 font-medium" />
                            <span asp-validation-for="DisplayName" class="text-xs text-red-600"></span>
                        </div>

                        <div class="space-y-2">
                            <label asp-for="Email" class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1"></label>
                            <input asp-for="Email" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-orange-500/20 text-slate-900 font-medium" />
                            <span asp-validation-for="Email" class="text-xs text-red-600"></span>
                        </div>

                        <div class="space-y-2">
                            <label asp-for="PhoneNumber" class="text-xs font-bold uppercase tracking-wider text-slate-500 ml-1"></label>
                            <input asp-for="PhoneNumber" class="w-full px-4 py-3 rounded-xl bg-surface-container-low border-none focus:ring-2 focus:ring-orange-500/20 text-slate-900 font-medium" />
                            <span asp-validation-for="PhoneNumber" class="text-xs text-red-600"></span>
                        </div>

                        <button class="w-full mt-4 py-4 rounded-xl bg-gradient-to-r from-primary to-primary-container text-white font-bold text-lg shadow-lg shadow-orange-500/20 hover:scale-[1.02] active:scale-95 transition-all" type="submit">
                            Lưu thay đổi
                        </button>
                    </form>
                </section>

                <section class="flex flex-col gap-8">
                    <div class="bg-surface-container-lowest rounded-3xl p-8 shadow-sm">
                        <div class="flex items-center gap-3 mb-8">
                            <div class="w-10 h-10 rounded-lg bg-orange-50 flex items-center justify-center text-orange-600">
                                <span class="material-symbols-outlined">lock</span>
                            </div>
                            <h3 class="text-xl font-headline font-extrabold text-slate-900">Bảo mật tài khoản</h3>
                        </div>

                        <p class="text-slate-600 mb-6">Đổi mật khẩu định kỳ để tăng cường bảo mật cho tài khoản của bạn.</p>
                        <a asp-action="ChangePassword" class="block w-full py-4 rounded-xl bg-slate-900 text-white font-bold text-lg hover:bg-slate-800 active:scale-95 transition-all text-center">
                            Cập nhật mật khẩu
                        </a>
                    </div>

                    <div class="flex-1 bg-primary-container rounded-3xl p-8 relative overflow-hidden group">
                        <div class="relative z-10 h-full flex flex-col justify-between">
                            <div>
                                <span class="inline-block px-3 py-1 rounded-full bg-white/20 text-white text-[10px] font-bold uppercase tracking-widest mb-4">Quản lý đơn hàng</span>
                                <h4 class="text-2xl font-headline font-black text-white leading-tight">Xem lại tất cả đơn hàng bạn đã đặt gần đây.</h4>
                            </div>
                            <a asp-action="OrderHistory" class="mt-8 px-6 py-2 bg-white text-orange-600 rounded-lg font-bold text-sm w-fit group-hover:scale-105 transition-transform">Xem đơn hàng</a>
                        </div>
                        <div class="absolute -bottom-10 -right-10 w-48 h-48 opacity-20 group-hover:rotate-12 transition-transform duration-700">
                            <span class="material-symbols-outlined text-[12rem]" style="font-variation-settings: 'FILL' 1;">shopping_bag</span>
                        </div>
                    </div>
                </section>
            </div>
        </div>
    </div>
</div>
