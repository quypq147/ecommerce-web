@model EcommerceApp.ViewModels.CheckoutSuccessViewModel
@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="w-full space-y-10">
    <section class="mx-auto max-w-3xl space-y-5 text-center">
        <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-full bg-primary-container/20">
            <span class="material-symbols-outlined text-5xl text-primary" style="font-variation-settings: 'FILL' 1;">check_circle</span>
        </div>
        <h1 class="font-headline text-6xl font-extrabold tracking-tight text-slate-900">Đặt hàng thành công!</h1>
        <p class="text-lg font-semibold text-slate-500">Mã đơn hàng: #@Model.OrderCode</p>
        <p class="text-slate-500">Cảm ơn bạn đã tin tưởng TechCurator. Đơn hàng của bạn đang được xử lý và sẽ sớm được giao đến bạn.</p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
            <a asp-controller="Account" asp-action="OrderHistory" class="inline-flex items-center gap-2 rounded-xl bg-gradient-to-br from-primary to-primary-container px-8 py-3 font-bold text-white">
                <span class="material-symbols-outlined text-base">local_shipping</span>
                Theo dõi đơn hàng
            </a>
            <a asp-controller="Store" asp-action="Index" class="rounded-xl bg-surface-container-high px-8 py-3 font-semibold text-slate-700">Tiếp tục mua sắm</a>
        </div>
    </section>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-12 lg:items-start">
        <div class="rounded-3xl border border-surface-variant/20 bg-surface-container-lowest p-8 lg:col-span-8">
            <div class="mb-6 flex items-center justify-between">
                <h2 class="text-4xl font-bold text-slate-900">Chi tiết sản phẩm</h2>
                <span class="text-xs font-bold uppercase tracking-widest text-slate-500">@Model.Items.Count món</span>
            </div>
            <div class="space-y-6">
                @foreach (var item in Model.Items)
                {
                    <div class="flex items-center gap-4">
                        <div class="h-14 w-14 overflow-hidden rounded-xl bg-surface-variant">
                            <img src="@item.Product.ImageUrl" alt="@item.Product.Name" class="h-full w-full object-cover" />
                        </div>
                        <div class="min-w-0 flex-1">
                            <p class="truncate font-bold text-slate-900">@item.Product.Name</p>
                            <p class="text-sm text-slate-500">Số lượng: @item.Quantity</p>
                        </div>
                        <span class="font-bold text-slate-900">@item.LineTotal.ToString("N0")đ</span>
                    </div>
                }
            </div>

            <div class="mt-8 space-y-3 border-t border-surface-variant/30 pt-6 text-sm">
                <div class="flex justify-between text-slate-500">
                    <span>Tạm tính</span>
                    <span>@Model.Subtotal.ToString("N0")đ</span>
                </div>
                <div class="flex justify-between text-slate-500">
                    <span>Phí vận chuyển</span>
                    <span class="font-semibold text-primary">Miễn phí</span>
                </div>
                <div class="flex justify-between pt-2 text-xl font-bold">
                    <span>Tổng cộng</span>
                    <span class="text-primary">@Model.Subtotal.ToString("N0")đ</span>
                </div>
            </div>
        </div>

        <div class="space-y-4 lg:col-span-4">
            <div class="rounded-3xl border border-surface-variant/20 bg-surface-container-low p-6">
                <div class="mb-4 flex items-center gap-2">
                    <span class="material-symbols-outlined text-primary">location_on</span>
                    <h3 class="text-lg font-bold text-slate-900">Địa chỉ giao hàng</h3>
                </div>
                <p class="font-semibold text-slate-800">@(string.IsNullOrWhiteSpace(Model.CustomerName) ? "Khách hàng" : Model.CustomerName)</p>
                <p class="mt-1 text-sm text-slate-500">Thông tin địa chỉ chi tiết sẽ được xác nhận qua điện thoại.</p>
            </div>

            <div class="rounded-3xl border border-surface-variant/20 bg-surface-container-highest/50 p-6 text-center">
                <span class="material-symbols-outlined text-3xl text-primary">headset_mic</span>
                <h3 class="mt-3 text-xl font-bold text-slate-900">Cần hỗ trợ?</h3>
                <p class="mt-2 text-sm text-slate-500">Đội ngũ chuyên gia của chúng tôi luôn sẵn sàng hỗ trợ bạn 24/7.</p>
                <a href="#" class="mt-4 inline-flex items-center gap-2 text-sm font-bold text-primary">Liên hệ bộ phận CSKH <span class="material-symbols-outlined text-base">arrow_forward</span></a>
            </div>
        </div>
    </div>
</div>
