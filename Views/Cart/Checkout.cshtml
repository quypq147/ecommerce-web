@model CheckoutViewModel
@{
    ViewData["Title"] = "Thanh toán";
}

<style>
    .btn-orange {
        background-color: #f39c12;
        color: white;
        border: none;
    }

        .btn-orange:hover {
            background-color: #e67e22;
            color: white;
        }

    .payment-container {
        border: 2px solid #7d5fff;
        border-radius: 8px;
        overflow: hidden;
        margin-top: 20px;
    }

    .order-summary {
        background-color: #f8f9fa;
        min-height: 400px;
        padding: 20px;
    }
</style>

<div class="container payment-container">
    <div class="row">
        <div class="col-md-7 p-4 bg-white">
            <h2 class="text-center mb-4">Thanh toán</h2>
            <form asp-action="ProcessCheckout" method="post">
                <div class="mb-3">
                    <label class="form-label">Họ và tên:</label>
                    <input asp-for="FullName" class="form-control bg-light" required />
                </div>
                <div class="mb-3">
                    <label class="form-label">Số thẻ:</label>
                    <input asp-for="CardNumber" class="form-control bg-light" required />
                </div>
                <div class="row mb-3">
                    <div class="col-8">
                        <label class="form-label">Ngày hết hạn:</label>
                        <input asp-for="ExpiryDate" class="form-control bg-light" placeholder="MM/YY" required />
                    </div>
                    <div class="col-4">
                        <label class="form-label">CVV:</label>
                        <input asp-for="CVV" class="form-control bg-light" required />
                    </div>
                </div>
                <div class="form-check mb-4">
                    <input asp-for="SaveInfo" class="form-check-input" type="checkbox">
                    <label class="form-check-label">Lưu thông tin thẻ</label>
                </div>
                <div class="d-flex justify-content-between">
                    <a asp-action="Index" class="btn btn-orange px-5">Hủy</a>
                    <button type="submit" class="btn btn-secondary px-5">Thanh toán</button>
                </div>
            </form>
        </div>

        <div class="col-md-5 order-summary border-start">
            <h4>Order của bạn</h4>
            <table class="table table-sm mt-3">
                <thead>
                    <tr><th>Sản phẩm</th><th>SL</th><th>Giá</th></tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.CartItems) {
                    <tr>
                        <td>@item.Product.Name</td>
                        <td>@item.Quantity</td>
                        <td>@item.Product.Price.ToString("N0")</td>
                    </tr>
                    }
                </tbody>
            </table>
            <h5 class="mt-4 pt-3 border-top">Tổng đơn: @Model.TotalAmount.ToString("N0") VNĐ</h5>
        </div>
    </div>
</div>