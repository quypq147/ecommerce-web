@model EcommerceApp.ViewModels.CartViewModel
@{
    ViewData["Title"] = "Giỏ hàng";
}

<div class="w-full space-y-6">
    @if (TempData["Message"] is string message)
    {
        <div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@message</div>
    }

    <div class="flex items-center justify-between">
        <h1 class="text-3xl font-bold text-slate-900">Giỏ hàng của bạn</h1>
        <a asp-controller="Store" asp-action="Index" class="text-sm font-medium text-orange-600">Tiếp tục mua sắm</a>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="rounded-2xl bg-white p-8 text-center text-slate-500 shadow-sm">Giỏ hàng của bạn đang trống.</div>
    }
    else
    {
        <div class="overflow-hidden rounded-2xl bg-white shadow-sm">
            <table class="min-w-full divide-y divide-slate-100">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Sản phẩm</th>
                        <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Giá</th>
                        <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Số lượng</th>
                        <th class="px-6 py-3 text-left text-xs font-bold uppercase tracking-wider text-slate-500">Thành tiền</th>
                        <th class="px-6 py-3"></th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td class="px-6 py-4 text-sm font-semibold text-slate-800">@item.Product.Name</td>
                            <td class="px-6 py-4 text-sm text-slate-600">@item.Product.Price.ToString("C")</td>
                            <td class="px-6 py-4">
                                <form asp-action="Update" method="post" class="flex items-center gap-2">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.Product.Id" />
                                    <input type="number" name="quantity" min="0" value="@item.Quantity" class="w-20 rounded-lg border-slate-200 text-sm" />
                                    <button type="submit" class="rounded-lg border border-slate-200 px-3 py-1.5 text-xs font-semibold text-slate-700">Cập nhật</button>
                                </form>
                            </td>
                            <td class="px-6 py-4 text-sm font-semibold text-slate-900">@item.LineTotal.ToString("C")</td>
                            <td class="px-6 py-4 text-right">
                                <form asp-action="Remove" method="post">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="productId" value="@item.Product.Id" />
                                    <button type="submit" class="text-sm font-medium text-red-500">Xóa</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="flex items-center justify-between rounded-2xl bg-white p-6 shadow-sm">
            <div class="text-sm text-slate-500">Tạm tính</div>
            <div class="text-2xl font-bold text-slate-900">@Model.Total.ToString("C")</div>
        </div>

        <form asp-controller="Checkout" asp-action="Index" method="get" class="text-right">
            <button type="submit" class="rounded-lg bg-orange-600 px-5 py-2 font-semibold text-white">
                Đặt hàng
            </button>
        </form>
    }
</div>
