@model EcommerceApp.ViewModels.WishlistViewModel
@{
    ViewData["Title"] = "Danh sách yêu thích";
}

<div class="w-full space-y-8">
    @if (TempData["Message"] is string message)
    {
        <div class="rounded-xl border border-green-200 bg-green-50 px-4 py-3 text-sm text-green-700">@message</div>
    }

    <div class="flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
        <div>
            <h1 class="font-headline text-5xl font-extrabold tracking-tight text-on-surface">Yêu thích</h1>
            <p class="mt-2 text-sm text-slate-500">Lưu lại các sản phẩm bạn muốn mua sau.</p>
        </div>

        @if (Model.Products.Any())
        {
            <form asp-action="Clear" method="post">
                @Html.AntiForgeryToken()
                <button type="submit" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Xóa tất cả</button>
            </form>
        }
    </div>

    @if (!Model.Products.Any())
    {
        <div class="rounded-2xl bg-white p-10 text-center text-slate-500 shadow-sm">
            <p class="mb-4">Danh sách yêu thích đang trống.</p>
            <a asp-controller="Store" asp-action="Index" class="inline-flex rounded-xl bg-orange-600 px-5 py-2.5 font-semibold text-white">Tiếp tục mua sắm</a>
        </div>
    }
    else
    {
        <div class="grid grid-cols-1 gap-6 md:grid-cols-2 xl:grid-cols-3">
            @foreach (var product in Model.Products)
            {
                <div class="rounded-2xl border border-slate-100 bg-white p-4 shadow-sm transition hover:shadow-md">
                    <a asp-controller="Store" asp-action="Details" asp-route-id="@product.Id" class="block overflow-hidden rounded-xl">
                        <img src="@product.ImageUrl" alt="@product.Name" class="mb-4 h-44 w-full object-cover transition duration-300 hover:scale-105" />
                    </a>
                    <div class="text-[11px] font-semibold uppercase tracking-[0.2em] text-orange-500">@product.Category?.Name</div>
                    <h2 class="text-xl font-bold text-slate-900">@product.Name</h2>
                    <p class="mt-1 line-clamp-2 text-sm text-slate-500">@product.Description</p>
                    <div class="mt-3 text-3xl font-bold text-slate-900">@product.Price.ToString("C")</div>

                    <div class="relative z-20 mt-4 flex flex-wrap gap-2">
                        <form asp-controller="Wishlist" asp-action="AddToCart" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@product.Id" />
                            <input type="hidden" name="returnUrl" value="@(Context.Request.Path + Context.Request.QueryString)" />
                            <button type="submit" class="rounded-xl bg-orange-500 px-4 py-2 text-sm font-semibold text-white">Thêm vào giỏ</button>
                        </form>

                        <form asp-action="Remove" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@product.Id" />
                            <button type="submit" class="rounded-xl border border-slate-300 px-4 py-2 text-sm font-semibold text-slate-700">Xóa</button>
                        </form>
                    </div>
                </div>
            }
        </div>
    }
</div>
