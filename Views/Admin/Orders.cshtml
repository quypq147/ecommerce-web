@model EcommerceApp.ViewModels.Admin.AdminOrdersViewModel
@using EcommerceApp.Models

<section class="space-y-8">
    @if (TempData["AdminMessage"] is string message)
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@message</div>
    }

    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
            <h2 class="text-4xl font-black text-on-surface">Order Management</h2>
            <p class="mt-2 text-secondary">Track orders, review details, and update fulfillment status.</p>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4 md:grid-cols-3">
        <div class="rounded-2xl bg-surface-container-low p-6">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-secondary">Total Orders</p>
            <p class="mt-2 text-4xl font-black text-on-surface">@Model.TotalOrders</p>
        </div>
        <div class="rounded-2xl bg-surface-container-low p-6">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-secondary">Pending Orders</p>
            <p class="mt-2 text-4xl font-black text-on-surface">@Model.PendingOrders</p>
        </div>
        <div class="rounded-2xl bg-surface-container-low p-6">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-secondary">Revenue</p>
            <p class="mt-2 text-4xl font-black text-on-surface">@Model.TotalRevenue.ToString("C")</p>
        </div>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-sm">
        <form action="/Admin/Orders" class="mb-5 grid gap-3 md:grid-cols-[1fr_auto_auto_auto]" method="get">
            <input class="w-full rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm"
                   name="search"
                   placeholder="Search by order id, customer, recipient..."
                   type="text"
                   value="@Model.Search" />

            <select class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm"
                    name="status">
                <option value="">All Status</option>
                @foreach (var status in Enum.GetValues<OrderStatus>())
                {
                    var selected = string.Equals(Model.StatusFilter, status.ToString(), StringComparison.OrdinalIgnoreCase);
                    <option selected="@selected" value="@status">@status</option>
                }
            </select>

            <button class="rounded-xl border border-outline-variant/50 px-4 py-3 text-sm font-semibold text-secondary" type="submit">Filter</button>
            <a class="rounded-xl border border-outline-variant/50 px-4 py-3 text-sm font-semibold text-secondary" href="/Admin/Orders">Reset</a>
        </form>

        @if (!Model.Orders.Any())
        {
            <div class="rounded-xl border border-dashed border-outline-variant/60 bg-surface-container-low px-6 py-10 text-center text-sm text-secondary">
                No orders found.
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full text-sm">
                    <thead>
                        <tr class="border-b border-surface-container-high text-left text-[11px] uppercase tracking-[0.15em] text-secondary">
                            <th class="pb-3">Order</th>
                            <th class="pb-3">Customer</th>
                            <th class="pb-3">Date</th>
                            <th class="pb-3">Items</th>
                            <th class="pb-3">Status</th>
                            <th class="pb-3">Amount</th>
                            <th class="pb-3 text-right">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var order in Model.Orders)
                        {
                            <tr class="border-b border-surface-container-low">
                                <td class="py-4 font-semibold text-on-surface">#@order.Id</td>
                                <td class="py-4">
                                    <p class="font-semibold text-on-surface">@order.RecipientName</p>
                                    <p class="text-xs text-secondary">@order.CustomerEmail</p>
                                </td>
                                <td class="py-4 text-secondary">@order.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="py-4 text-on-surface">@order.ItemCount</td>
                                <td class="py-4">
                                    <span class="rounded-full bg-surface-container-low px-3 py-1 text-xs font-semibold text-secondary">@order.Status</span>
                                </td>
                                <td class="py-4 font-semibold text-on-surface">@order.TotalAmount.ToString("C")</td>
                                <td class="py-4 text-right">
                                    <a class="rounded-lg border border-outline-variant/50 px-3 py-2 text-xs font-semibold text-secondary"
                                       href="/Admin/OrderDetails/@order.Id">View Details</a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</section>
