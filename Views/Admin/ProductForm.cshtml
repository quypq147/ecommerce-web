@model EcommerceApp.ViewModels.Admin.AdminProductFormViewModel

@{
    var isEdit = Model.Id.HasValue;
    var actionUrl = isEdit ? "/Admin/EditProduct" : "/Admin/CreateProduct";
}

<section class="mx-auto max-w-3xl rounded-2xl bg-white p-8 shadow-sm">
    <div class="mb-8 flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-on-surface">@(isEdit ? "Sửa sản phẩm" : "Thêm sản phẩm")</h2>
            <p class="mt-2 text-secondary">Quản lý sản phẩm trong trang quản trị.</p>
        </div>
        <a class="rounded-lg border border-outline-variant/50 px-4 py-2 text-sm font-semibold text-secondary" href="/Admin/Products">Quay lại</a>
    </div>

    @if (!ViewData.ModelState.IsValid)
    {
        <div class="mb-6 rounded-xl border border-error/20 bg-error/5 px-4 py-3 text-sm text-error">
            @Html.ValidationSummary(excludePropertyErrors: false)
        </div>
    }

    <form action="@actionUrl" class="space-y-5" enctype="multipart/form-data" method="post">
        @Html.AntiForgeryToken()
        @if (isEdit)
        {
            <input name="Id" type="hidden" value="@Model.Id" />
        }

        <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-secondary">Tên</label>
            <input class="w-full rounded-xl border border-outline-variant/50 px-4 py-3" name="Name" type="text" value="@Model.Name" />
        </div>

        <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-secondary">Mô tả</label>
            <textarea class="w-full rounded-xl border border-outline-variant/50 px-4 py-3" name="Description" rows="4">@Model.Description</textarea>
        </div>

        <div class="grid grid-cols-1 gap-5 md:grid-cols-2">
            <div>
                <label class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-secondary">Giá</label>
                <input class="w-full rounded-xl border border-outline-variant/50 px-4 py-3" min="0" name="Price" step="0.01" type="number" value="@Model.Price" />
            </div>
            <div>
                <label class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-secondary">Tồn kho</label>
                <input class="w-full rounded-xl border border-outline-variant/50 px-4 py-3" min="0" name="StockQuantity" type="number" value="@Model.StockQuantity" />
            </div>
        </div>

        <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-secondary">Ảnh sản phẩm</label>
            <input accept="image/*" class="w-full rounded-xl border border-outline-variant/50 px-4 py-3" name="ImageFile" type="file" />
            @if (!string.IsNullOrWhiteSpace(Model.ImageUrl))
            {
                <div class="mt-3 inline-flex items-center gap-3 rounded-xl bg-surface-container-low px-3 py-2">
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="h-12 w-12 rounded-lg object-cover" />
                    <span class="text-xs text-secondary">Giữ ảnh hiện tại nếu không chọn ảnh mới.</span>
                </div>
            }
        </div>

        <div>
            <label class="mb-2 block text-xs font-bold uppercase tracking-[0.16em] text-secondary">Danh mục</label>
            <select id="category-select" class="w-full rounded-xl border border-outline-variant/50 px-4 py-3" name="CategoryId">
                <option value="">Chọn danh mục</option>
                @foreach (var category in Model.Categories)
                {
                    var categoryLabel = string.IsNullOrWhiteSpace(category.Icon)
                        ? category.Name
                        : $"{category.Icon} • {category.Name}";
                    if (category.Id == Model.CategoryId)
                    {
                        <option selected="selected" data-icon="@category.Icon" value="@category.Id">@categoryLabel</option>
                    }
                    else
                    {
                        <option data-icon="@category.Icon" value="@category.Id">@categoryLabel</option>
                    }
                }
            </select>
            <p class="mt-1 inline-flex items-center gap-2 text-xs text-secondary">
                <span id="category-selected-icon" class="material-symbols-outlined text-base">category</span>
                Biểu tượng danh mục hiện tại
            </p>
        </div>

        <button class="inline-flex rounded-xl bg-primary px-5 py-3 text-sm font-bold text-white" type="submit">
            @(isEdit ? "Lưu thay đổi" : "Tạo sản phẩm")
        </button>
    </form>
</section>

@section Scripts {
    <script>
        (() => {
            const select = document.getElementById('category-select');
            const iconTarget = document.getElementById('category-selected-icon');
            if (!select || !iconTarget) return;

            const update = () => {
                const selectedOption = select.options[select.selectedIndex];
                const icon = (selectedOption?.dataset.icon || '').trim().replace(/\s+/g, '_').toLowerCase();
                iconTarget.textContent = icon || 'category';
            };

            select.addEventListener('change', update);
            update();
        })();
    </script>
}
