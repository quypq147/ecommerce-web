@model EcommerceApp.ViewModels.Admin.AdminOrderDetailsViewModel
@using EcommerceApp.Models

<section class="space-y-8">
    @if (TempData["AdminMessage"] is string message)
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@message</div>
    }

    <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
            <h2 class="text-4xl font-black text-on-surface">Order #@Model.Id</h2>
            <p class="mt-2 text-secondary">Created @Model.CreatedAtUtc.ToLocalTime().ToString("yyyy-MM-dd HH:mm")</p>
        </div>
        <a class="inline-flex items-center justify-center rounded-xl border border-outline-variant/50 px-4 py-3 text-sm font-semibold text-secondary"
           href="/Admin/Orders">Back to Orders</a>
    </div>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
        <div class="rounded-2xl bg-surface-container-low p-6">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-secondary">Status</p>
            <p class="mt-2 text-2xl font-black text-on-surface">@Model.Status</p>
            <p class="mt-2 text-xs text-secondary">Last updated: @(Model.UpdatedAtUtc?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "-" )</p>
        </div>
        <div class="rounded-2xl bg-surface-container-low p-6">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-secondary">Customer</p>
            <p class="mt-2 text-lg font-semibold text-on-surface">@Model.RecipientName</p>
            <p class="text-sm text-secondary">@Model.CustomerEmail</p>
        </div>
        <div class="rounded-2xl bg-surface-container-low p-6">
            <p class="text-xs font-bold uppercase tracking-[0.18em] text-secondary">Total Amount</p>
            <p class="mt-2 text-2xl font-black text-on-surface">@Model.TotalAmount.ToString("C")</p>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-2">
        <div class="rounded-2xl bg-white p-6 shadow-sm">
            <h3 class="text-lg font-black text-on-surface">Update Status</h3>
            <form action="/Admin/UpdateOrderStatus" class="mt-4 space-y-4" method="post">
                @Html.AntiForgeryToken()
                <input name="orderId" type="hidden" value="@Model.Id" />

                <select class="w-full rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm"
                        name="status">
                    @foreach (var status in Enum.GetValues<OrderStatus>())
                    {
                        <option selected="@(status == Model.Status)" value="@status">@status</option>
                    }
                </select>

                <button class="rounded-xl bg-primary px-5 py-3 text-sm font-bold text-white hover:opacity-90" type="submit">
                    Save Status
                </button>
            </form>
        </div>

        <div class="rounded-2xl bg-white p-6 shadow-sm">
            <h3 class="text-lg font-black text-on-surface">Shipping Address</h3>
            <form action="/Admin/UpdateOrderAddress" class="mt-4 grid gap-3" method="post">
                @Html.AntiForgeryToken()
                <input name="orderId" type="hidden" value="@Model.Id" />

                <input class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm" name="recipientName" placeholder="Recipient name" value="@Model.RecipientName" />
                <input class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm" name="phoneNumber" placeholder="Phone" value="@Model.PhoneNumber" />
                <input class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm" name="addressLine1" placeholder="Address line 1" value="@Model.AddressLine1" />
                <input class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm" name="addressLine2" placeholder="Address line 2" value="@Model.AddressLine2" />
                <input class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm" name="city" placeholder="City" value="@Model.City" />
                <input class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm" name="stateOrProvince" placeholder="State / Province" value="@Model.StateOrProvince" />
                <input class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm" name="postalCode" placeholder="Postal code" value="@Model.PostalCode" />
                <input class="rounded-xl border border-outline-variant/50 bg-surface-container-low px-4 py-3 text-sm" name="country" placeholder="Country" value="@Model.Country" />

                <button class="rounded-xl bg-primary px-5 py-3 text-sm font-bold text-white hover:opacity-90" type="submit">
                    Save Address
                </button>
            </form>
        </div>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-sm">
        <h3 class="text-lg font-black text-on-surface">Order Items</h3>
        <div class="mt-4 overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead>
                    <tr class="border-b border-surface-container-high text-left text-[11px] uppercase tracking-[0.15em] text-secondary">
                        <th class="pb-3">Product</th>
                        <th class="pb-3">Unit Price</th>
                        <th class="pb-3">Quantity</th>
                        <th class="pb-3">Line Total</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr class="border-b border-surface-container-low">
                            <td class="py-4 font-semibold text-on-surface">@item.ProductName</td>
                            <td class="py-4 text-on-surface">@item.UnitPrice.ToString("C")</td>
                            <td class="py-4 text-on-surface">@item.Quantity</td>
                            <td class="py-4 font-semibold text-on-surface">@item.LineTotal.ToString("C")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
