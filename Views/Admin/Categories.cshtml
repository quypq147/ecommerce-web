@section Scripts {
    <script>
        (() => {
            const picker = document.getElementById('new-icon-picker');
            const trigger = document.getElementById('new-icon-trigger');
            const menu = document.getElementById('new-icon-menu');
            const hidden = document.getElementById('new-category-icon');
            const iconPreview = document.getElementById('new-category-icon-preview');
            const iconLabel = document.getElementById('new-category-icon-label');
            if (!picker || !trigger || !menu || !hidden || !iconPreview || !iconLabel) return;

            trigger.addEventListener('click', () => menu.classList.toggle('hidden'));

            menu.querySelectorAll('.icon-option').forEach(option => {
                option.addEventListener('click', () => {
                    const icon = option.dataset.icon || 'category';
                    hidden.value = icon;
                    iconPreview.textContent = icon;
                    iconLabel.textContent = icon;
                    menu.classList.add('hidden');
                });
            });

            document.addEventListener('click', (event) => {
                if (!picker.contains(event.target)) {
                    menu.classList.add('hidden');
                }
            });
        })();
    </script>
}
