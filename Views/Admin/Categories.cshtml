@model EcommerceApp.ViewModels.Admin.AdminCategoriesViewModel

<section class="space-y-8">
    @if (TempData["AdminMessage"] is string message)
    {
        <div class="rounded-xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-700">@message</div>
    }

    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-black text-on-surface">Categories</h2>
            <p class="mt-2 text-secondary">Create and maintain product categories in admin module.</p>
        </div>
        <a class="rounded-lg border border-outline-variant/50 px-4 py-2 text-sm font-semibold text-secondary" href="/Admin">Back to Products</a>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-sm">
        <h3 class="text-lg font-black text-on-surface">Add Category</h3>
        <form action="/Admin/CreateCategory" class="mt-5 grid grid-cols-1 gap-4 md:grid-cols-3" method="post">
            @Html.AntiForgeryToken()
            <input class="rounded-xl border border-outline-variant/50 px-4 py-3 md:col-span-1" name="Name" placeholder="Category name" type="text" value="@Model.NewCategory.Name" />
            <input class="rounded-xl border border-outline-variant/50 px-4 py-3 md:col-span-1" name="Description" placeholder="Description" type="text" value="@Model.NewCategory.Description" />
            <button class="rounded-xl bg-primary px-4 py-3 text-sm font-bold text-white md:col-span-1" type="submit">Create Category</button>
        </form>
    </div>

    <div class="rounded-2xl bg-white p-6 shadow-sm">
        <div class="overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead>
                    <tr class="border-b border-surface-container-high text-left text-[11px] uppercase tracking-[0.15em] text-secondary">
                        <th class="pb-3">Name</th>
                        <th class="pb-3">Description</th>
                        <th class="pb-3">Products</th>
                        <th class="pb-3 text-right">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var category in Model.Categories)
                    {
                        <tr class="border-b border-surface-container-low">
                            <td class="py-4 font-semibold text-on-surface">@category.Name</td>
                            <td class="py-4 text-secondary">@category.Description</td>
                            <td class="py-4 text-on-surface">@category.ProductCount</td>
                            <td class="py-4">
                                <div class="flex items-center justify-end gap-2">
                                    <a class="rounded-lg border border-outline-variant/50 px-3 py-2 text-xs font-semibold text-secondary"
                                       href="/Admin/EditCategory/@category.Id">Edit</a>
                                    <form action="/Admin/DeleteCategory/@category.Id" method="post" onsubmit="return confirm('Delete this category?');">
                                        @Html.AntiForgeryToken()
                                        <button class="rounded-lg border border-error/30 px-3 py-2 text-xs font-semibold text-error" type="submit">Delete</button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>
