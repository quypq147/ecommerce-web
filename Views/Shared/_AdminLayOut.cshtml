@{
    var path = Context?.Request?.Path.Value?.ToLowerInvariant() ?? string.Empty;
    var productsActive = path == "/admin" || path.StartsWith("/admin/createproduct") || path.StartsWith("/admin/editproduct");
    var categoriesActive = path.StartsWith("/admin/categories") || path.StartsWith("/admin/editcategory");
    var ordersActive = path.StartsWith("/admin/orders") || path.StartsWith("/admin/orderdetails");

    string NavClass(bool active) => active
        ? "flex items-center gap-3 rounded-xl bg-white px-4 py-3 font-semibold text-[#ff8c00] shadow-sm"
        : "flex items-center gap-3 px-4 py-3 text-[#565e74] hover:bg-white/50 transition-all duration-200";
}

<!DOCTYPE html>
<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Bảng quản trị | TechCurator</title>
    <script src="https://cdn.tailwindcss.com?plugins=forms"></script>
    <link href="https://fonts.googleapis.com" rel="preconnect" />
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    colors: {
                        primary: "#904d00",
                        secondary: "#565e74",
                        background: "#f7f9fb",
                        "on-surface": "#191c1e",
                        "surface-container-low": "#f2f4f6",
                        "surface-container-high": "#e6e8ea",
                        "outline-variant": "#ddc1ae",
                        error: "#ba1a1a"
                    }
                }
            }
        };
    </script>
    <style>
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Plus Jakarta Sans', sans-serif; }
        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }
    </style>
</head>
<body class="min-h-screen bg-background text-on-surface">
    <div class="flex min-h-screen">
        <aside class="fixed left-0 top-0 flex h-screen w-64 flex-col border-r border-[#565e74]/10 bg-[#f7f9fb] p-6">
            <div class="mb-10">
                <h1 class="text-lg font-black tracking-tight text-[#565e74]">Bảng quản trị</h1>
                <p class="text-xs font-medium text-secondary/60">Trung tâm Tech Curator</p>
            </div>

            <nav class="flex-grow space-y-2">
                <a class="@NavClass(productsActive)" href="/Admin">
                    <span class="material-symbols-outlined text-xl">inventory_2</span>
                    <span class="text-sm">Sản phẩm</span>
                </a>
                <a class="@NavClass(categoriesActive)" href="/Admin/Categories">
                    <span class="material-symbols-outlined text-xl">category</span>
                    <span class="text-sm">Danh mục</span>
                </a>
                <a class="@NavClass(ordersActive)" href="/Admin/Orders">
                    <span class="material-symbols-outlined text-xl">shopping_cart</span>
                    <span class="text-sm">Đơn hàng</span>
                </a>
            </nav>

            <div class="mt-auto space-y-2 pt-6">
                <form action="/Account/Logout" method="post">
                    @Html.AntiForgeryToken()
                    <button class="flex w-full items-center gap-3 px-4 py-3 text-error hover:bg-error/5" type="submit">
                        <span class="material-symbols-outlined text-xl">logout</span>
                        <span class="text-sm font-medium">Đăng xuất</span>
                    </button>
                </form>
            </div>
        </aside>

        <main class="ml-64 flex min-h-screen flex-grow flex-col">
            <header class="sticky top-0 z-40 flex items-center justify-between bg-white/85 px-8 py-4 shadow-[0_24px_40px_-15px_rgba(86,94,116,0.06)] backdrop-blur-xl">
                <span class="text-xl font-bold tracking-tight text-[#565e74]">Nhà tuyển chọn số</span>
                <div class="flex items-center gap-4">
                    <span class="material-symbols-outlined text-secondary">notifications</span>
                    <span class="material-symbols-outlined text-secondary">settings</span>
                </div>
            </header>

            <div class="mx-auto w-full max-w-7xl flex-grow p-8">
                @RenderBody()
            </div>

            <footer class="p-8 text-center">
                <p class="text-[10px] font-bold uppercase tracking-[0.2em] text-secondary/40">© 2024 The Digital Curator • Giao diện quản trị v2.4</p>
            </footer>
        </main>
    </div>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
