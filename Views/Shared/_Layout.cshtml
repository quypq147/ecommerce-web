<!DOCTYPE html>

<html class="light" lang="vi">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&amp;family=Inter:wght@400;500;600;700&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet" />
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
        darkMode: "class",
        theme: {
        extend: {
        colors: {
        "primary-fixed": "#ffdcc3",
        "on-background": "#191c1e",
        "primary-fixed-dim": "#ffb77d",
        "on-primary-container": "#623200",
        "outline-variant": "#ddc1ae",
        "surface-container-lowest": "#ffffff",
        "surface-container-highest": "#e0e3e5",
        "tertiary-container": "#00b5fc",
        "primary-container": "#ff8c00",
        "surface": "#f7f9fb",
        "surface-dim": "#d8dadc",
        "tertiary": "#00658f",
        "on-surface": "#191c1e",
        "on-primary": "#ffffff",
        "surface-container": "#eceef0",
        "secondary-fixed-dim": "#bec6e0",
        "on-tertiary": "#ffffff",
        "secondary": "#565e74",
        "on-secondary-container": "#5c647a",
        "surface-variant": "#e0e3e5",
        "surface-container-low": "#f2f4f6",
        "on-error-container": "#93000a",
        "on-secondary-fixed": "#131b2e",
        "on-secondary": "#ffffff",
        "on-tertiary-container": "#004360",
        "outline": "#897362",
        "error": "#ba1a1a",
        "primary": "#904d00",
        "on-surface-variant": "#564334",
        "tertiary-fixed-dim": "#85cfff",
        "surface-bright": "#f7f9fb",
        "tertiary-fixed": "#c7e7ff",
        "on-tertiary-fixed": "#001e2e",
        "on-primary-fixed": "#2f1500",
        "surface-tint": "#904d00",
        "secondary-fixed": "#dae2fd",
        "inverse-primary": "#ffb77d",
        "on-primary-fixed-variant": "#6e3900",
        "surface-container-high": "#e6e8ea",
        "on-tertiary-fixed-variant": "#004c6c",
        "inverse-surface": "#2d3133",
        "background": "#f7f9fb",
        "error-container": "#ffdad6",
        "on-secondary-fixed-variant": "#3f465c",
        "inverse-on-surface": "#eff1f3",
        "on-error": "#ffffff",
        "secondary-container": "#dae2fd"
        },
        fontFamily: {
        "headline": ["Plus Jakarta Sans"],
        "body": ["Inter"],
        "label": ["Inter"]
        },
        borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
        },
        },
        }
    </script>
    <style>
        .material-symbols-outlined {
        font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .editorial-shadow {
        box-shadow: 0 24px 40px -10px rgba(25, 28, 30, 0.04);
        }
        .glass-nav {
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        }
    </style>
</head>
<body class="bg-surface font-body text-on-surface selection:bg-primary-fixed selection:text-on-primary-fixed">
    <!-- TopNavBar -->
    <nav class="fixed top-0 w-full z-50 glass-nav bg-white/80 border-b border-outline-variant/10">
        <div class="flex justify-between items-center px-8 h-16 w-full max-w-7xl mx-auto">
            <a asp-controller="Store" asp-action="Index" class="text-2xl font-black tracking-tighter text-orange-600">TechCurator</a>
            <div class="hidden md:flex space-x-8">
                <a asp-controller="Store" asp-action="Index" class="text-orange-600 font-bold border-b-2 border-orange-600 text-sm tracking-wide">Sản phẩm</a>
                <a asp-controller="Cart" asp-action="Index" class="text-slate-600 font-medium hover:text-orange-500 transition-colors duration-200 text-sm tracking-wide">Giỏ Hàng</a>
                <a asp-controller="Home" asp-action="Privacy" class="text-slate-600 font-medium hover:text-orange-500 transition-colors duration-200 text-sm tracking-wide">Bảo Mật</a>
            </div>
            <div class="flex items-center space-x-6">
                <div class="relative hidden lg:block">
                    <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-lg">search</span>
                    <input class="pl-10 pr-4 py-1.5 bg-surface-container-low border-none rounded-full text-sm w-64 focus:ring-2 focus:ring-primary-container focus:bg-white transition-all" placeholder="Tìm kiếm linh kiện..." type="text" />
                </div>
                <a asp-controller="Cart" asp-action="Index" class="text-slate-600 hover:text-orange-500 scale-95 active:scale-90 transition-transform">
                    <span class="material-symbols-outlined">shopping_cart</span>
                </a>
                @if (User.Identity?.IsAuthenticated == true)
                {
                    <a asp-controller="Account" asp-action="Profile" class="text-slate-600 hover:text-orange-500 scale-95 active:scale-90 transition-transform" title="Profile">
                        <span class="material-symbols-outlined">account_circle</span>
                    </a>
                    <form asp-controller="Account" asp-action="Logout" method="post" class="inline">
                        <button type="submit" class="text-slate-600 hover:text-orange-500 scale-95 active:scale-90 transition-transform" title="Logout">
                            <span class="material-symbols-outlined">logout</span>
                        </button>
                    </form>
                }
                else
                {
                    <a asp-controller="Account" asp-action="Login" class="text-slate-600 hover:text-orange-500 scale-95 active:scale-90 transition-transform" title="Login">
                        <span class="material-symbols-outlined">account_circle</span>
                    </a>
                }
            </div>
        </div>
    </nav>
    <main class="max-w-7xl mx-auto pt-24 pb-20 px-8 flex gap-12">
        <!-- Sidebar Filter -->
        @RenderBody()
        
    </main>
    <!-- Footer -->
    <footer class="bg-white border-t border-slate-100 mt-20">
        <div class="max-w-7xl mx-auto px-8 py-16 grid grid-cols-1 md:grid-cols-4 gap-12">
            <div class="space-y-6">
                <div class="text-xl font-bold text-slate-900 tracking-tighter">TechCurator</div>
                <p class="text-sm text-slate-500 leading-relaxed max-w-xs">Điểm đến hàng đầu cho các giải pháp máy tính cao cấp và linh kiện PC chuyên nghiệp tại Việt Nam.</p>
                <div class="flex space-x-4">
                    <a class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 hover:text-orange-600 transition-colors border border-slate-100" href="#">
                        <span class="material-symbols-outlined text-sm">share</span>
                    </a>
                    <a class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 hover:text-orange-600 transition-colors border border-slate-100" href="#">
                        <span class="material-symbols-outlined text-sm">alternate_email</span>
                    </a>
                    <a class="w-8 h-8 rounded-full bg-slate-50 flex items-center justify-center text-slate-400 hover:text-orange-600 transition-colors border border-slate-100" href="#">
                        <span class="material-symbols-outlined text-sm">near_me</span>
                    </a>
                </div>
            </div>
            <div>
                <h4 class="font-headline font-bold text-sm uppercase tracking-widest text-slate-900 mb-6">Sản phẩm</h4>
                <ul class="space-y-3">
                    <li><a class="text-slate-500 hover:text-orange-500 underline text-sm transition-all" href="#">Laptops Gaming</a></li>
                    <li><a class="text-slate-500 hover:text-orange-500 underline text-sm transition-all" href="#">Build PC Trọn Bộ</a></li>
                    <li><a class="text-slate-500 hover:text-orange-500 underline text-sm transition-all" href="#">Card Đồ Họa</a></li>
                    <li><a class="text-slate-500 hover:text-orange-500 underline text-sm transition-all" href="#">Màn Hình Cao Cấp</a></li>
                </ul>
            </div>
            <div>
                <h4 class="font-headline font-bold text-sm uppercase tracking-widest text-slate-900 mb-6">Hỗ trợ</h4>
                <ul class="space-y-3">
                    <li><a class="text-slate-500 hover:text-orange-500 underline text-sm transition-all" href="#">Chính sách bảo hành</a></li>
                    <li><a class="text-slate-500 hover:text-orange-500 underline text-sm transition-all" href="#">Hướng dẫn trả góp</a></li>
                    <li><a class="text-slate-500 hover:text-orange-500 underline text-sm transition-all" href="#">Vận chuyển &amp; Giao nhận</a></li>
                    <li><a class="text-slate-500 hover:text-orange-500 underline text-sm transition-all" href="#">Liên hệ chúng tôi</a></li>
                </ul>
            </div>
            <div class="bg-surface-container-low p-6 rounded-2xl">
                <h4 class="font-headline font-bold text-sm uppercase tracking-widest text-slate-900 mb-4">Newsletter</h4>
                <p class="text-xs text-slate-500 mb-4">Nhận thông báo về các sản phẩm mới nhất và ưu đãi độc quyền.</p>
                <div class="relative">
                    <input class="w-full text-xs py-3 px-4 rounded-xl border-none focus:ring-1 focus:ring-primary-container bg-white shadow-sm" placeholder="Email của bạn" type="email" />
                    <button class="absolute right-2 top-1/2 -translate-y-1/2 text-orange-600">
                        <span class="material-symbols-outlined">send</span>
                    </button>
                </div>
            </div>
        </div>
        <div class="max-w-7xl mx-auto px-8 py-8 border-t border-slate-100 flex flex-col md:flex-row justify-between items-center text-[10px] font-bold uppercase tracking-widest text-slate-400">
            <div>© 2024 TechCurator Vietnam. All rights reserved.</div>
            <div class="flex space-x-6 mt-4 md:mt-0">
                <a class="hover:text-slate-900" href="#">Chính sách bảo mật</a>
                <a class="hover:text-slate-900" href="#">Dịch Vụ</a>
                <a class="hover:text-slate-900" href="#">Bảo mật</a>
            </div>
        </div>
    </footer>
    @await RenderSectionAsync("Scripts", required: false)
</body></html>
