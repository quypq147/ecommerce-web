<!DOCTYPE html>

<html lang="vi"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>@(ViewData["Title"] ?? "TechCurator - Tài khoản")</title>
<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;700;800&amp;family=Inter:wght@400;500;600&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "background": "#f7f9fb",
              "secondary-container": "#dae2fd",
              "error-container": "#ffdad6",
              "primary-fixed": "#ffdcc3",
              "on-surface": "#191c1e",
              "secondary-fixed": "#dae2fd",
              "surface-container-low": "#f2f4f6",
              "inverse-primary": "#ffb77d",
              "primary": "#904d00",
              "on-primary-fixed-variant": "#6e3900",
              "on-surface-variant": "#564334",
              "on-tertiary-container": "#004360",
              "outline": "#897362",
              "on-tertiary-fixed": "#001e2e",
              "surface-tint": "#904d00",
              "surface-container": "#eceef0",
              "on-secondary-fixed-variant": "#3f465c",
              "on-error-container": "#93000a",
              "on-tertiary": "#ffffff",
              "on-primary-container": "#623200",
              "on-primary": "#ffffff",
              "surface-container-high": "#e6e8ea",
              "inverse-surface": "#2d3133",
              "surface-dim": "#d8dadc",
              "surface-container-highest": "#e0e3e5",
              "on-secondary-fixed": "#131b2e",
              "on-background": "#191c1e",
              "surface-container-lowest": "#ffffff",
              "inverse-on-surface": "#eff1f3",
              "tertiary": "#00658f",
              "tertiary-container": "#00b5fc",
              "on-secondary": "#ffffff",
              "on-tertiary-fixed-variant": "#004c6c",
              "outline-variant": "#ddc1ae",
              "primary-container": "#ff8c00",
              "on-primary-fixed": "#2f1500",
              "on-secondary-container": "#5c647a",
              "surface-bright": "#f7f9fb",
              "tertiary-fixed-dim": "#85cfff",
              "surface-variant": "#e0e3e5",
              "error": "#ba1a1a",
              "primary-fixed-dim": "#ffb77d",
              "on-error": "#ffffff",
              "tertiary-fixed": "#c7e7ff",
              "surface": "#f7f9fb",
              "secondary-fixed-dim": "#bec6e0",
              "secondary": "#565e74"
            },
            fontFamily: {
              "headline": ["Plus Jakarta Sans"],
              "body": ["Inter"],
              "label": ["Inter"]
            },
            borderRadius: {"DEFAULT": "0.25rem", "lg": "0.5rem", "xl": "0.75rem", "full": "9999px"},
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        body { font-family: 'Inter', sans-serif; }
        h1, h2, h3 { font-family: 'Plus Jakarta Sans', sans-serif; }
    </style>
</head>
<body class="bg-background text-on-background min-h-screen flex flex-col items-center justify-center p-6 relative overflow-x-hidden">
<div class="absolute top-0 left-0 w-full h-[409px] bg-gradient-to-br from-primary/10 via-background to-background -z-10 opacity-50"></div>
<div class="absolute -top-24 -right-24 w-96 h-96 bg-primary-container/10 rounded-full blur-3xl -z-10"></div>
<div class="absolute bottom-24 -left-24 w-64 h-64 bg-tertiary-container/10 rounded-full blur-3xl -z-10"></div>
<div class="w-full max-w-md flex flex-col items-center">
@{
    var action = ViewContext.RouteData.Values["action"]?.ToString();
    var isLogin = string.Equals(action, "Login", StringComparison.OrdinalIgnoreCase);
    var isRegister = string.Equals(action, "Register", StringComparison.OrdinalIgnoreCase);
}
<div class="mb-10 flex flex-col items-center gap-3">
<div class="w-16 h-16 bg-gradient-to-br from-primary to-primary-container rounded-xl flex items-center justify-center shadow-lg shadow-primary/20 rotate-3">
<span class="material-symbols-outlined text-white text-4xl" data-weight="fill">developer_board</span>
</div>
<h1 class="text-2xl font-black tracking-tighter text-primary">TechCurator</h1>
<p class="text-secondary font-medium tracking-wide text-sm uppercase">Cửa hàng phần cứng cao cấp</p>
</div>
<div class="w-full bg-surface-container-lowest rounded-3xl shadow-xl shadow-slate-200/50 p-8 border border-white/50 backdrop-blur-sm">
<div class="flex gap-1 p-1 bg-surface-container-low rounded-xl mb-8">
<a asp-controller="Account" asp-action="Login" class="flex-1 py-2.5 px-4 text-sm rounded-lg text-center transition-all @(isLogin ? "font-bold bg-surface-container-lowest text-primary shadow-sm" : "font-semibold text-secondary hover:text-on-surface")">
                    Đăng nhập
                </a>
<a asp-controller="Account" asp-action="Register" class="flex-1 py-2.5 px-4 text-sm rounded-lg text-center transition-all @(isRegister ? "font-bold bg-surface-container-lowest text-primary shadow-sm" : "font-semibold text-secondary hover:text-on-surface")">
                    Đăng ký
                </a>
</div>
@RenderBody()
</div>
<div class="mt-16 flex items-center justify-center gap-8 text-slate-400">
<a class="text-[0.7rem] font-bold uppercase tracking-widest hover:text-primary transition-colors" href="#">Về chúng tôi</a>
<a class="text-[0.7rem] font-bold uppercase tracking-widest hover:text-primary transition-colors" href="#">Bảo mật</a>
<a class="text-[0.7rem] font-bold uppercase tracking-widest hover:text-primary transition-colors" href="#">Hỗ trợ</a>
</div>
</div>
<div class="fixed bottom-8 right-8 flex flex-col gap-4">
<button class="w-12 h-12 bg-white dark:bg-slate-800 text-primary shadow-xl rounded-full flex items-center justify-center hover:scale-110 active:scale-95 transition-all">
<span class="material-symbols-outlined">headset_mic</span>
</button>
</div>
@await RenderSectionAsync("Scripts", required: false)
</body></html>
